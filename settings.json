  "gopls": {
    "ui.diagnostic.staticcheck": true,
    "ui.semanticTokens": true,
    "verboseOutput": true,
    "codelenses": {
      "gc_details": true,
      "test": true
    },
    "analyses": {
      "ST1000": false,
      "ST1003": false,
      "ST1020": false,
      "ST1021": false,
      "QF1001": true,
      "QF1007": true,
      "QF1011": true,
      "S1002": true,
      "S1005": true,
      "S1025": true,
      "S1029": true,
      "SA1014": true,
      "SA1017": true,
      "SA1029": true,
      "SA1030": true,
      "SA1031": true,
      "SA1032": true,
      "SA4023": true,
      "SA5000": true
    },
    "usePlaceholders": true,
    "completeUnimported": true,
    "deepCompletion": true,
    "hoverKind": "FullDocumentation"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },
  "go.inlayHints.functionTypeParameters": true,
  "go.inlayHints.constantValues": false,
  "go.disableConcurrentTests": true,
  "go.coverOnSingleTest": false,
  "go.coverOnTestPackage": true,
  "go.lintOnSave": "workspace",
